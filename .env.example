# Server
PORT=3000
DATABASE_PATH=./server/data/platform.db
SCREENSHOTS_DIR=./server/data/screenshots

# Capture
BROWSER_HEADLESS=true
CAPTURE_TIMEOUT_MS=30000
CAPTURE_VIEWPORT_WIDTH=1440
CAPTURE_VIEWPORT_HEIGHT=900

# Claude API — required for AI-assist features (tag suggestions, draft syntheses)
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Logging
LOG_LEVEL=info
